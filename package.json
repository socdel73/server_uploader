{
  "name": "server-uploader",
  "version": "1.0.0",
  "description": "Electron desktop app for uploading files and folders to remote servers over SSH and rsync.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "build": "electron-builder --mac dmg --win nsis"
  },
  "keywords": [
    "electron",
    "ssh",
    "rsync",
    "upload",
    "deployment"
  ],
  "author": "socdel73",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.socdel73.serveruploader",
    "productName": "Server Uploader",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "styles.css",
      "package.json",
      "node_modules/**/*",
      "!config.json",
      "!server_uploader.zip",
      "!server_uploader.txt",
      "!docs{,/**}",
      "!dist{,/**}",
      "!release{,/**}"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1"
  }
}
